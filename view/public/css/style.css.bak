/* -----------------------------------------
   PALETTE GLOBALE LS MOTORS
----------------------------------------- */
:root {
    --noir: #050506;
    --noir-soft: #0d0d10;
    --anthracite: #16161a;
    --anthracite-clair: #1f1f26;
    --blanc: #f5f5f7;
    --gris-clair: #cfcfd4;
    --gris-moyen: #8f9096;
    --doré: #c9a227;
    --doré-foncé: #a38218;
    --rouge-erreur: #c0392b;
}

/* -----------------------------------------
   BODY GLOBAL
----------------------------------------- */
body {
    background-color: var(--noir-soft) !important;
    color: var(--blanc) !important;
    font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

/* Fix pour éviter le décalage horizontal */
html,
body {
    max-width: 100%;
    overflow-x: hidden;
}

/* -----------------------------------------
   LIENS
----------------------------------------- */
a {
    color: var(--doré);
    text-decoration: none;
}

a:hover {
    color: var(--gris-clair);
    text-decoration: none;
}

/* -----------------------------------------
   TITRES
----------------------------------------- */
h1,
h2,
h3,
h4,
h5,
h6 {
    color: var(--blanc);
    font-weight: 600;
}

/* -----------------------------------------
   OVERRIDE BOOTSTRAP UTILS (bg/text/border)
----------------------------------------- */

/* Fonds sombres */
.bg-dark,
.bg-black,
.bg-body,
.bg-secondary {
    background-color: var(--noir-soft) !important;
}

/* Textes */
.text-light {
    color: var(--blanc) !important;
}

.text-secondary {
    color: var(--gris-moyen) !important;
}

/* Bordures */
.border,
.border-secondary {
    border-color: var(--doré) !important;
}

/* Tables */
.table {
    color: var(--blanc);
    background-color: var(--anthracite-clair);
}

.table thead th {
    color: var(--blanc);
    background-color: var(--anthracite);
    border-bottom: 2px solid var(--doré);
}

.table tbody tr {
    border-color: var(--anthracite);
}

.table tbody tr:nth-child(even) {
    background-color: #18181f;
}

.table tbody tr:hover {
    background-color: #20202a;
}

/* -----------------------------------------
   NAVBAR
----------------------------------------- */
.navbar {
    background: linear-gradient(90deg, var(--noir) 0%, #121218 40%, #181820 100%);
    border-bottom: 1px solid var(--doré);
}

.navbar-brand,
.navbar-nav .nav-link {
    color: var(--blanc) !important;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: 0.9rem;
}

.navbar-nav .nav-link.active,
.navbar-nav .nav-link:hover {
    color: var(--doré) !important;
}

/* -----------------------------------------
   CARTES / BLOCS / PANNEAUX
----------------------------------------- */
.card {
    background: radial-gradient(circle at top left, #262633 0, var(--anthracite) 40%, #101018 100%);
    color: var(--blanc);
    border: 1px solid var(--doré-foncé);
    border-radius: 0.5rem;
    box-shadow: 0 0 12px rgba(0, 0, 0, 0.7);
}

.card-header {
    background-color: rgba(0, 0, 0, 0.4);
    border-bottom: 1px solid var(--doré-foncé);
    color: var(--blanc);
}

.card-footer {
    background-color: rgba(0, 0, 0, 0.4);
    border-top: 1px solid var(--doré-foncé);
}

/* Encadrés/gros blocs type accueil */
.box-gold,
.border-gold {
    background: linear-gradient(135deg, #191921, #13131a);
    border: 1px solid var(--doré-foncé);
    border-radius: 0.75rem;
    padding: 1.5rem;
}

/* -----------------------------------------
   FORMULAIRES
----------------------------------------- */
.form-control,
.form-select {
    background-color: #13131a;
    border: 1px solid #3a3a48;
    color: var(--blanc);
}

.form-control:focus,
.form-select:focus {
    background-color: #15151f;
    color: var(--blanc);
    border-color: var(--doré);
    box-shadow: 0 0 0 0.15rem rgba(201, 162, 39, 0.4);
}

.form-label {
    color: var(--gris-clair);
}

/* Placeholders */
::placeholder {
    color: #696979 !important;
}

/* -----------------------------------------
   BOUTONS
----------------------------------------- */
.btn {
    border-radius: 0.4rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    transition: all 0.18s ease-in-out;
}

/* Bouton principal doré */
.btn-primary {
    background: linear-gradient(135deg, var(--doré) 0, var(--doré-foncé) 100%);
    border: none;
    color: var(--noir);
}

.btn-primary:hover {
    background: linear-gradient(135deg, #e1c15a 0, var(--doré) 100%);
    color: var(--noir);
    transform: translateY(-1px);
}

/* Bouton secondaire "outline" doré */
.btn-outline-primary,
.btn-outline-warning {
    border-color: var(--doré);
    color: var(--doré);
    background-color: transparent;
}

.btn-outline-primary:hover,
.btn-outline-warning:hover {
    background-color: var(--doré);
    color: var(--noir);
}

/* Bouton danger (suppression etc.) */
.btn-danger {
    background-color: var(--rouge-erreur);
    border: none;
}

.btn-danger:hover {
    background-color: #e74c3c;
}

/* -----------------------------------------
   ALERTES / MESSAGES
----------------------------------------- */
.alert {
    border-radius: 0.5rem;
}

.alert-success {
    background-color: #14532d;
    border-color: #22c55e;
    color: #bbf7d0;
}

.alert-danger {
    background-color: #450a0a;
    border-color: #f87171;
    color: #fecaca;
}

.alert-warning {
    background-color: #451a03;
    border-color: #facc15;
    color: #fef3c7;
}

/* -----------------------------------------
   FOOTER
----------------------------------------- */
footer {
    background: linear-gradient(90deg, #050506, #101018, #050506);
    border-top: 1px solid var(--doré);
    color: var(--gris-clair);
    font-size: 0.85rem;
}

/* -----------------------------------------
   TABLES DE GESTION ADMIN
----------------------------------------- */
.table-actions .btn {
    padding: 0.25rem 0.6rem;
    font-size: 0.8rem;
}

/* -----------------------------------------
   DIVERS
----------------------------------------- */

/* Séparateurs dorés */
.hr-gold {
    border: 0;
    border-top: 1px solid var(--doré);
    opacity: 0.6;
    margin: 1.5rem 0;
}

/* Badge / labels */
.badge-gold {
    background-color: var(--doré);
    color: var(--noir);
    border-radius: 999px;
    padding: 0.3rem 0.7rem;
    font-size: 0.75rem;
    font-weight: 600;
}

/* Petites ombres propres */
.shadow-soft {
    box-shadow: 0 0 18px rgba(0, 0, 0, 0.65);
}


/* Logo navbar */
.navbar-logo-img {
    height: 46px;
    /* ajuste ici si tu veux plus grand/petit */
    width: auto;
    image-rendering: auto;
}

/* Ajuste la hauteur de la navbar */
.navbar {
    padding-top: 12px !important;
    padding-bottom: 12px !important;
}/* -----------------------------------------
   NOUVEAUTE
----------------------------------------- */


/* Légende couleurs prix (admin ventes employés) */
.price-legend{
  display: flex;
  flex-wrap: wrap;
  gap: 14px;
  align-items: center;
}

.price-legend .legend-item{
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 0.95rem;
}

.price-legend .legend-swatch{
  width: 14px;
  height: 14px;
  border-radius: 3px;
  display: inline-block;
  border: 1px solid rgba(255,255,255,0.35);
}

/* Bloc légende couleurs prix - Admin ventes employés */
.price-legend-box{
    background-color: #111;
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 6px;
    padding: 10px 14px;
    max-width: 420px;
}

.price-legend-box .legend-line{
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.9rem;
    margin-bottom: 6px;
}

.price-legend-box .legend-line:last-child{
    margin-bottom: 0;
}

.price-legend-box .legend-square{
    width: 14px;
    height: 14px;
    border-radius: 3px;
    flex-shrink: 0;
}

/* Couleurs */
.legend-success .legend-square{
    background-color: #28a745;
}
.legend-warning .legend-square{
    background-color: #ffc107;
}
.legend-danger .legend-square{
    background-color: #dc3545;
}
.legend-primary .legend-square{
    background-color: #0d6efd;
}/* Admin Finances - colonnes inputs + ligne détails */
.col-input{
    width: 160px;
}

.finance-details-row td{
    background-color: rgba(255,255,255,0.02);
    border-top: 0;
}